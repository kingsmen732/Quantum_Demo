# pnpm-lock.yaml

# next.js
/.next/
/out/
/.turbo/
/.cache/
.swc/

# production
/build

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
logs
*.log
.eslintcache

# env files
.env*
!.env.example

# os files
.DS_Store
Thumbs.db

